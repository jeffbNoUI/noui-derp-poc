      },
      {
        "step": 4,
        "name": "death_benefit_continuation",
        "inputs": { "total": 5000.00, "election": "100_installments", "months_paid": 27 },
        "rule": "RULE-DEATH-ELECTION",
        "calculation": "100 - 27 = 73 remaining installments; 73 × $50.00 = $3,650.00",
        "result": { "months_remaining": 73, "amount_remaining": 3650.00, "monthly": 50.00 }
      },
      {
        "step": 5,
        "name": "ipr_termination",
        "inputs": { "member_ipr": 189.84, "member_deceased": true },
        "rule": "RULE-IPR",
        "calculation": "IPR is a member benefit — assumed to terminate at death",
        "result": { "ipr_continues": false }
      },
      {
        "step": 6,
        "name": "payment_summary",
        "inputs": { "survivor_benefit": 2436.00, "death_installment": 50.00 },
        "rule": "SYSTEM",
        "calculation": "$2,436.00 + $50.00 = $2,486.00 total monthly (for 73 months), then $2,436.00",
        "result": { "initial_total": 2486.00, "eventual_total": 2436.00 }
      }
    ]
