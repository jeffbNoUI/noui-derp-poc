                                                    reductionRatePerYear = 0.06. UPDATE AlertBar: tier                                       
                                                    badge shows \'Tier 3 --- Post-July 2011\'.                                               

  **member.tier === 1 \|\| member.tier === 2**      RECONFIGURE SalaryTable: set amsWindow.months =    SalaryTable (reconfig)                Cases 1, 2, 4
                                                    36. If early retirement: reductionRatePerYear =                                          
                                                    0.03.                                                                                    

  **eligibility.type === \'early\'**                ADD EarlyRetirementReductionCalculator after       EarlyRetirementReductionCalculator,   Cases 2, 3
                                                    BenefitCalculationPanel (order 5.3). ADD alert     AlertBar update                       
                                                    (warning): \'Early retirement reduction applies:                                         
                                                    X% (Y years under 65)\'. SET                                                             
                                                    BenefitCalculationPanel.reductionApplied = true.                                         

  **eligibility.type === \'rule_of\'**              ADD alert (success): \'Rule of 75/85 met --- no    AlertBar update                       Cases 1, 4
                                                    benefit reduction\'. REMOVE                                                              
                                                    EarlyRetirementReductionCalculator if present.                                           

  **member.purchasedServiceYears \> 0**             ADD ServiceCreditSummary after EmploymentTimeline  ServiceCreditSummary, AlertBar update Case 2
                                                    (order 3.5). ADD alert (warning): \'Member has                                           
