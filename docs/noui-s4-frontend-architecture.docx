>
> ams: number;
>
> amsWindowMonths: 36 \| 60;
>
> serviceYears: number; // total credited service
>
> unreducedMonthlyBenefit: number;
>
> unreducedAnnualBenefit: number;
>
> reductionApplied: boolean;
>
> reductionPercent: number; // 0 if none
>
> reductionSource?: string; // \'Early retirement 3%/yr\'
>
> reducedMonthlyBenefit?: number;
>
> reducedAnnualBenefit?: number;
>
> formulaDisplay: string; // e.g., \'2.0% x \$10,639.45 x 28.75\'
>
> statuteRefs: StatuteRef\[\];
>
> verificationStatus: \'verified\' \| \'pending\' \| \'discrepancy\';
>
> calculationTimestamp: string;
>
> }
>
> interface StatuteRef {
>
> section: string; // e.g., \'§18-401(a)\'
>
> description: string; // e.g., \'Benefit multiplier\'
>
> }

